---
interface Props {
  avatar: string;
  name: string;
  date: string;
}

const { avatar, name, date } = Astro.props;
---

<div class="message">
  <img class="avatar" src={avatar} alt={name} />
  <div class="body">
    <div class="header">
      <span class="name">{name}</span>
      <span class="date">{date}</span>
    </div>
    <div class="content"><slot /></div>
  </div>
</div>

<style>
  .message {
    display: flex;
    gap: 16px;
    padding: 12px 16px;
  }

  .avatar,
  .name,
  .date {
    cursor: pointer;
  }

  .avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 2px;
    object-fit: cover;
  }

  .body {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .header {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }

  .name {
    font-weight: 600;
    font-size: 15px;
    color: var(--text);
  }

  .date {
    font-size: 11px;
    font-weight: 500;
    color: color-mix(in srgb, var(--text) 40%, transparent);
  }

  .content {
    font-size: 15px;
    color: color-mix(in srgb, var(--text) 85%, transparent);
    line-height: 1.4;
  }

  .content :global(h1) {
    font-size: 22px;
  }
  .content :global(h2) {
    font-size: 18px;
  }
  .content :global(h3) {
    font-size: 15px;
  }

  .content :global(ul),
  .content :global(ol) {
    margin: 0;
    padding-left: 20px;
    list-style-position: outside;
  }

  .content :global(ul li) {
    list-style-type: disc;
  }

  .content :global(ol li) {
    list-style-type: decimal;
  }
</style>
