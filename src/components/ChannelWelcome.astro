---
interface Props {
  page: string;
}

const { page } = Astro.props;
---

<div class="welcome">
  <div class="icon">#</div>
  <h2 class="title">Welcome to <span class="highlight">#{page}!</span></h2>
</div>

<style>
  .welcome {
    padding: 16px 16px 8px;
  }

  .icon {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    font-size: 48px;
    font-weight: 700;
    color: var(--text);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
  }

  .title {
    font-size: 26px;
    font-weight: 600;
    color: var(--text);
    margin: 0;
  }

  .highlight {
    color: var(--text);
  }
</style>
