---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<div class="app">
  <slot />
</div>

<style>
  .app {
    display: flex;
    height: 100vh;
    overflow: hidden;
    background-image: url("bg.gif");
  }

  .main {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: var(--bg-primary);
  }

  .page-header {
    height: 48px;
    min-height: 48px;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0 16px;
    font-weight: 600;
    font-size: 15px;
    color: var(--text);
    border-bottom: 1px solid var(--border);
  }

  .hash {
    color: color-mix(in srgb, var(--text) 50%, transparent);
    font-size: 20px;
    line-height: 1;
  }

  .content {
    flex: 1;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    scrollbar-width: none;
  }

  .content::-webkit-scrollbar {
    display: none;
  }

  .spacer {
    flex: 1;
  }

  .no-permission {
    margin: 8px;
    padding: 12px 16px;
    border-radius: 8px;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    color: color-mix(in srgb, var(--text) 50%, transparent);
    font-size: 14px;
    display: flex;
    align-items: center;
    gap: 12px;
    cursor: not-allowed;
  }
</style>

<script>
  function scrollToBottom(): void {
    const content = document.querySelector("main.content");
    if (content) content.scrollTop = content.scrollHeight;
  }

  document.addEventListener("astro:page-load", scrollToBottom);
</script>
